{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "command": {
    "init-project": {
      "description": "Initialize project documentation through iterative Q&A",
      "template": "Project description: $ARGUMENTS\n\n{file:./.agents/phases/init-project.md}"
    },
    "plan-feature": {
      "description": "Plan a feature: /plan-feature <feature-id or description>",
      "template": "Feature request: $ARGUMENTS\n\n{file:./.agents/phases/plan-feature.md}"
    },
    "exec-feature": {
      "description": "Implement a feature: /exec-feature <feature-id>",
      "template": "Feature ID: $ARGUMENTS\n\n{file:./.agents/phases/exec-feature.md}"
    },
    "embed-feature": {
      "description": "Integrate a feature: /embed-feature <feature-id>",
      "template": "Feature ID: $ARGUMENTS\n\n{file:./.agents/phases/embed-feature.md}"
    }
  }
}
